# ─── LLM Provider ────────────────────────────────────────────────────────────
# One of: anthropic | openai | gemini | ollama
LLM_PROVIDER=anthropic

# ─── API Keys (only set the one you use) ─────────────────────────────────────
# Keys are stored locally and never sent anywhere except the provider you choose.
ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=AIza...

# ─── Model Selection ─────────────────────────────────────────────────────────
# Anthropic: claude-sonnet-4-6 | claude-haiku-4-5-20251001
ANTHROPIC_MODEL=claude-sonnet-4-6
# OpenAI: gpt-4o | gpt-4o-mini
OPENAI_MODEL=gpt-4o
# Gemini: gemini-2.0-flash | gemini-1.5-pro
GEMINI_MODEL=gemini-2.0-flash
# Ollama (local): llama3.2 | mistral | phi3
OLLAMA_MODEL=llama3.2
OLLAMA_BASE_URL=http://localhost:11434

# ─── Database ────────────────────────────────────────────────────────────────
# Defaults to ~/.grainsift/grainsift.db (SQLite). Override for PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/grainsift
DATABASE_URL=

# ─── Processing ──────────────────────────────────────────────────────────────
# Items per LLM call (1–10, default 5)
BATCH_SIZE=5
# Items with confidence below this go to human review queue
CONFIDENCE_THRESHOLD=0.65
# Feedback longer than this (words) gets chunked
MAX_FEEDBACK_WORDS=400

# ─── Server ──────────────────────────────────────────────────────────────────
HOST=127.0.0.1
PORT=8000
DEBUG=false
